# DEVS Bridge - Environment Variables
# Copy this file to .env and fill in the values

# Google OAuth (shared across Drive, Gmail, Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Notion OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Qonto OAuth
QONTO_CLIENT_ID=
QONTO_CLIENT_SECRET=

# Microsoft OAuth - Outlook Mail and OneDrive
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Figma OAuth
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_SIGNING_SECRET=
FIGMA_VERIFICATION_SECRET=

# Dropbox OAuth
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# Optional: Server configuration
# HOST=0.0.0.0
# PORT=4445
# LOG_LEVEL=info
